{
  "name": "opencode-plus",
  "version": "0.1.2",
  "description": "TDD Actor-Critic workflow system for OpenCode - structured test-driven development with AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "commands",
    "docs",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tdd",
    "test-driven-development",
    "testing",
    "ai-agents",
    "actor-critic",
    "code-generation",
    "workflow"
  ],
  "author": "kishb87",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kishb87/opencode-plus"
  },
  "bugs": {
    "url": "https://github.com/kishb87/opencode-plus/issues"
  },
  "homepage": "https://github.com/kishb87/opencode-plus#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
